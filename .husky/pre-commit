#!/usr/bin/env sh
# Pre-commit chain (run in order, stops on first failure):
#   0a. Python size+complexity gate (ruff) on first-party tactical/ modules
#   0b. Bash file-size gate (wc -l) on scripts/**/*.sh + deployment/**/*.sh
#   0c. Secret scan — AWS/GH/Slack/PEM/Anthropic/OpenAI/Stripe/JWT/GCP-SA in staged diff
#   1.  lint-staged (eslint --fix + prettier --write on staged files)
#   1b. trunk check --index (hold-the-line — blocks on NEW lint issues only)
#   1c. fallow audit (baseline-aware — blocks on NEW dead-code/dupes/complexity findings only)
#
# CodeRabbit pre-commit was removed 2026-04-24 — it was adding 30-60 s per
# commit, failing most invocations, and duplicated the server-side CodeRabbit
# review that runs on every push to GitHub. The GitHub-side review is the
# authoritative one; Claude's coderabbit:autofix skill processes its output.
#
# Full-repo ESLint scan runs in pre-push (keeps commits fast, still blocks bad code from reaching remote).
#
# Skip the Python gate with:    SKIP_PY_GATE=1 git commit ...
# Skip the bash size gate with: SKIP_SIZE_GATE=1 git commit ...
# Skip the secret scan with:    SKIP_SECRET_SCAN=1 git commit ...  (rotate the credential instead!)
# Skip the trunk gate with:     SKIP_TRUNK=1 git commit ...
# Skip the fallow gate with:    SKIP_FALLOW=1 git commit ...
# Skip everything with:         git commit --no-verify ...

set -e

# 0a) Python size + complexity gate (blocking)
if [ "${SKIP_PY_GATE:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_PY_GATE=1 — skipping Python ruff gate"
else
	PY_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- 'tactical/**/*.py' | grep -v '^tactical/blue-dragon/' || true)
	if [ -n "$PY_FILES" ]; then
		if command -v ruff >/dev/null 2>&1; then
			RUFF=ruff
		elif [ -x "$HOME/.local/bin/ruff" ]; then
			RUFF="$HOME/.local/bin/ruff"
		else
			echo "[pre-commit] ruff not found on PATH; install with 'pipx install ruff' or set SKIP_PY_GATE=1 (not recommended)" >&2
			exit 1
		fi
		echo "[pre-commit] Python size/complexity gate (ruff E501,C901,PLR0915)..."
		# shellcheck disable=SC2086
		$RUFF check $PY_FILES --select=E501,C901,PLR0915 || {
			echo "[pre-commit] Python size/complexity gate failed" >&2
			exit 1
		}
	fi
fi

# 0b) Bash file-size gate (blocking — 300 LOC/file hard cap per CLAUDE.md)
if [ "${SKIP_SIZE_GATE:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_SIZE_GATE=1 — skipping bash size gate"
else
	SH_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- 'scripts/**/*.sh' 'deployment/**/*.sh' || true)
	if [ -n "$SH_FILES" ]; then
		SIZE_FAIL=0
		for f in $SH_FILES; do
			[ -f "$f" ] || continue
			lines=$(wc -l < "$f")
			if [ "$lines" -gt 300 ]; then
				echo "[pre-commit] $f: $lines LOC exceeds 300-LOC cap (bash size gate)" >&2
				SIZE_FAIL=1
			fi
		done
		if [ "$SIZE_FAIL" = "1" ]; then
			echo "[pre-commit] Bash size gate failed — split oversized scripts per CLAUDE.md Code Conventions" >&2
			exit 1
		fi
	fi
fi

# 0c) Secret scan (blocking — inspects only added lines in staged diff)
# Patterns: AWS, GH PAT family, Slack, PEM, Anthropic, OpenAI, Stripe, GCP SA, generic JWT.
if [ "${SKIP_SECRET_SCAN:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_SECRET_SCAN=1 — skipping secret scan"
else
	SECRET_PATTERNS='AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9]{36,}|xox[abpsr]-[A-Za-z0-9-]{10,}|-----BEGIN[[:space:]]+(RSA|OPENSSH|DSA|EC|PGP)?[[:space:]]*PRIVATE KEY-----|sk-ant-api03-[A-Za-z0-9_-]{93,}|sk-(proj-)?[A-Za-z0-9_-]{40,}|sk_live_[A-Za-z0-9]{24,}|rk_live_[A-Za-z0-9]{24,}|eyJ[A-Za-z0-9_-]+\.eyJ[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+|"type"[[:space:]]*:[[:space:]]*"service_account"'
	ADDED=$(git diff --cached --no-color -U0 --diff-filter=ACMR -- . ':(exclude)package-lock.json' ':(exclude)**/*.lock' ':(exclude)**/*.lockb' 2>/dev/null | grep -E '^\+[^+]' || true)
	if [ -n "$ADDED" ] && echo "$ADDED" | grep -qE "$SECRET_PATTERNS"; then
		echo "[pre-commit] ❌ potential secret detected in staged changes:" >&2
		echo "$ADDED" | grep -nE "$SECRET_PATTERNS" | head -20 >&2
		echo "" >&2
		echo "[pre-commit] ROTATE the credential BEFORE pushing — it is already in the staging area." >&2
		echo "[pre-commit] If this is a false positive, bypass with: SKIP_SECRET_SCAN=1 git commit ..." >&2
		exit 1
	fi
fi

# 1) Lint + format staged files (blocking)
npx lint-staged

# 1b) Trunk Code Quality gate (blocking — hold-the-line: only NEW issues fire)
# Scans staged files via git index. Existing baseline issues are ignored.
# Gated on presence of .trunk/trunk.yaml so repos without trunk skip cleanly.
if [ "${SKIP_TRUNK:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_TRUNK=1 — skipping trunk check"
elif [ -f .trunk/trunk.yaml ]; then
	if ! command -v npx >/dev/null 2>&1; then
		echo "[pre-commit] ❌ .trunk/trunk.yaml present but \`npx\` not on PATH" >&2
		echo "[pre-commit]    Install Node/npm or bypass with: SKIP_TRUNK=1 git commit ..." >&2
		exit 1
	fi
	echo "[pre-commit] trunk check --index (hold-the-line)..."
	if ! npx trunk check --index --no-progress; then
		echo "[pre-commit] ❌ trunk check found NEW lint issues on staged changes" >&2
		echo "[pre-commit]    Fix with: npx trunk check --index --fix" >&2
		echo "[pre-commit]    Bypass:   SKIP_TRUNK=1 git commit ..." >&2
		exit 1
	fi
fi

# 1c) Fallow audit gate (blocking — baseline-aware, only NEW findings fire)
# Scoped to changed files vs auto-detected base branch. Existing baseline
# findings (244 complexity, 129 dupes, 223 dead exports as of day-1) are
# grandfathered via .fallow-{deadcode,health,dupes}-baseline.json checked
# into the repo root. Gated on presence of .fallowrc.json so repos without
# fallow skip cleanly.
#
# CRITICAL — UPSTREAM BUG WORKAROUND (fallow.tools v2.63.0, observed 2026-05-04):
# `fallow audit --gate new-only` (the default) materializes the base branch
# into a tempdir at /tmp/fallow-audit-base-<pid>-<nonce>/ for "introduced vs
# inherited" attribution. That materialization uses git plumbing that LEAKS
# index entries back into the parent worktree's .git/index, staging hundreds
# of phantom file deletions. We snapshot .git/index before the fallow call
# and restore it afterwards regardless of exit code, so any leaked staging
# is reversed before husky returns control to git. Verified clean via the
# instrumentation pass at /home/jetson2/.claude/plans/proceed-with-creating-the-radiant-nest.md.
if [ "${SKIP_FALLOW:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_FALLOW=1 — skipping fallow audit"
elif [ -f .fallowrc.json ]; then
	if ! command -v npx >/dev/null 2>&1; then
		echo "[pre-commit] ❌ .fallowrc.json present but \`npx\` not on PATH" >&2
		echo "[pre-commit]    Install Node/npm or bypass with: SKIP_FALLOW=1 git commit ..." >&2
		exit 1
	fi
	echo "[pre-commit] fallow audit (baseline-aware: NEW complexity/dupes/dead-code only)..."
	# Index snapshot/restore wrap (fallow audit upstream-bug workaround).
	# Use git rev-parse --git-dir so this works in both main checkout (.git is a dir)
	# and worktrees (.git is a file pointing to <maindir>/worktrees/<name>/).
	_fallow_gitidx="$(git rev-parse --git-dir)/index"
	_fallow_idx_bak="$(mktemp /tmp/fallow-idx-bak.XXXXXX)"
	cp "$_fallow_gitidx" "$_fallow_idx_bak"
	_fallow_rc=0
	npx --no-install fallow audit --quiet --format compact || _fallow_rc=$?
	# Restore index regardless of fallow exit code so any leaked staging is reversed.
	cp "$_fallow_idx_bak" "$_fallow_gitidx"
	rm -f "$_fallow_idx_bak"
	if [ "$_fallow_rc" -ne 0 ]; then
		echo "[pre-commit] ❌ fallow audit found NEW issues vs baseline on staged changes" >&2
		echo "[pre-commit]    Inspect: npx --no-install fallow audit --format human --explain" >&2
		echo "[pre-commit]    Bypass:  SKIP_FALLOW=1 git commit ..." >&2
		exit 1
	fi
fi

exit 0
