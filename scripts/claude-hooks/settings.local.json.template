{
  "permissions": {
    "allow": [
      "Bash(npx fallow:*)",
      "Bash(npx --no-install fallow:*)",
      "Bash(./node_modules/.bin/fallow:*)",
      "Bash(fallow audit:*)",
      "Bash(fallow health:*)",
      "Bash(fallow dupes:*)",
      "Bash(fallow dead-code:*)",
      "Bash(fallow init:*)",
      "Bash(fallow config:*)",
      "Bash(fallow hooks:*)",
      "Bash(fallow setup-hooks:*)",
      "Bash(fallow fix --dry-run:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/cleanup-stale-daemons.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-sensitive-files.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/memory-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/hardware-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/git-quality-gate.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/memory-check.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-format.sh",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-lint.sh",
            "timeout": 30,
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/audit-log.sh",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/desktop-notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/smart-cleanup.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory",
  "spinnerTipsEnabled": false,
  "mcpServers": {
    "tailwindcss": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "tailwindcss-mcp-server"],
      "env": {}
    },
    "svelte-remote": {
      "type": "http",
      "url": "https://mcp.svelte.dev/mcp"
    },
    "argos-system-inspector": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "src/lib/server/mcp/servers/system-inspector.ts"],
      "env": {
        "NODE_ENV": "development",
        "ARGOS_API_URL": "http://localhost:5173",
        "ARGOS_API_KEY": "__ARGOS_API_KEY__"
      }
    },
    "argos-database-inspector": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "src/lib/server/mcp/servers/database-inspector.ts"],
      "env": {
        "NODE_ENV": "development",
        "ARGOS_API_URL": "http://localhost:5173",
        "ARGOS_API_KEY": "__ARGOS_API_KEY__"
      }
    },
    "argos-api-debugger": {
      "type": "stdio",
      "command": "npx",
      "args": ["tsx", "src/lib/server/mcp/servers/api-debugger.ts"],
      "env": {
        "NODE_ENV": "development",
        "ARGOS_API_URL": "http://localhost:5173",
        "ARGOS_API_KEY": "__ARGOS_API_KEY__"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless",
        "--isolated",
        "--no-usage-statistics",
        "--no-performance-crux",
        "--chrome-arg=--crash-dumps-dir=/tmp/chromium-crashes",
        "--chrome-arg=--disable-crash-reporter"
      ],
      "env": {}
    }
  }
}
