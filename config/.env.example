# =============================================================================
# Argos SDR & Network Analysis Console — Environment Configuration
# =============================================================================
# SECURITY: Copy this file to .env and set ALL required values before starting.
# The system will REFUSE TO START if ARGOS_API_KEY is not configured.
# =============================================================================

# Authentication (REQUIRED — system will not start without this)
ARGOS_API_KEY=                    # REQUIRED. Min 32 chars. Generate: openssl rand -hex 32
# NOTE: There is no localhost-only mode. API key is always required. (Regrade A3: fail-closed)
# NOTE: API key is accepted via X-API-Key header for programmatic access. (Regrade A4)
# NOTE: Browser clients receive a secure session cookie automatically on page load.

# Required Variables
KISMET_API_URL=http://localhost:2501   # Validated as URL — must include scheme
DATABASE_PATH=./rf_signals.db
NODE_ENV=development

# Server Configuration
PUBLIC_BASE_URL=http://localhost:5173
PORT=5173

# Backend API Configuration
PUBLIC_API_BASE_URL=http://localhost:8005
PUBLIC_WS_URL=ws://localhost:8005

# Direct Service Endpoints
PUBLIC_KISMET_API_URL=http://localhost:2501
PUBLIC_WIGLETOAK_API_URL=http://localhost:8000  # legacy — see WIGLETOTAK_PORT below

# WebSocket Configuration
PUBLIC_KISMET_WS_URL=ws://localhost:2501

# Docker (third-party tools only — OpenWebRX, NovaSDR, Bettercap)
PUBLIC_OPENWEBRX_URL=http://localhost:8073
PUBLIC_NOVASDR_URL=http://localhost:9002

# Feature Flags
PUBLIC_ENABLE_DEBUG=false
PUBLIC_ENABLE_MOCK_DATA=false

# Kismet Configuration
KISMET_HOST=localhost
KISMET_PORT=2501
KISMET_USER=admin
KISMET_PASSWORD=                  # REQUIRED — no default
KISMET_API_KEY=

# Kismet REST API Configuration
KISMET_REST_USER=admin
KISMET_REST_PASSWORD=             # REQUIRED — no default

# Bettercap Configuration
BETTERCAP_USER=admin
BETTERCAP_PASSWORD=               # REQUIRED — no default

# OpenWebRX Configuration
OPENWEBRX_PASSWORD=               # REQUIRED — no default

# GPSD socket path (default: /var/run/gpsd.sock)
# GPSD_SOCKET_PATH=/var/run/gpsd.sock

# GSM Evil Configuration
GSMEVIL_DIR=                      # Path to GsmEvil2 clone. Default: $HOME/gsmevil2

# BlueHood Bluetooth Scanner Configuration
BLUEHOOD_PORT=8085                # Web dashboard port. Default: 8085

# WigleToTAK Configuration
WIGLETOTAK_PORT=8081              # Flask web UI port. Default: 8081 (8000 reserved for Chroma)

# OpenCellID Configuration
OPENCELLID_API_KEY=               # REQUIRED — no default

# Stadia Maps Configuration (for map tiles)
STADIA_MAPS_API_KEY=              # REQUIRED — no default. Get from https://stadiamaps.com/

# CloudRF Configuration (for RF propagation cloud engine)
CLOUDRF_API_KEY=                  # Optional. Get from https://cloudrf.com

# Access Point Configuration (for scripts/create-ap-simple.sh)
AP_PASSWORD=                      # REQUIRED when creating WiFi AP

# Sentry Configuration (Error tracking + performance monitoring)
PUBLIC_SENTRY_DSN=                # Public DSN — sent to browser. Get from Sentry project settings.
SENTRY_AUTH_TOKEN=                # Server/build-only. Used for source-maps upload at build time.

# Key Rotation Schedule (NIST SP 800-53 IA-5):
# - ARGOS_API_KEY: Every 90 days or immediately upon suspected compromise
# - Service credentials: Every 90 days or when rotating service containers
# - Generate new key: openssl rand -hex 32
# - After rotation: verify old key returns 401
