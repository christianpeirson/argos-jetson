# Large data files
map-data/*.csv

/.quarto/
**/*.quarto_ipynb

# Blue Dragon — embedded third-party git repo from alphafox02/blue-dragon
# Security patches applied via scripts/ops/apply-blue-dragon-patches.sh on install.
# Patches are tracked in tactical/blue-dragon-patches/ (outside the embedded repo).
tactical/blue-dragon/

# Remediation rollback snapshots (local-only pre-flight state)
.rollback/

# Security — IDE settings with secrets
.vscode/settings.json

# Dev tooling (not project code)
claude-code-lsp-enforcement-kit/

# Binary artifacts (distribute via releases)
*.apk

# Trunk Code Quality local state (all entries symlink into ~/.cache/trunk)
.trunk/

# Timestamped backup files (e.g., foo.sh.bak.20260423-215327). `*.bak` above only matches the exact `.bak` suffix.
*.bak.*

# Cell tower CSV dump — reconstitute from data/celltowers/towers.db or release asset
docs/cell_towers.csv.gz

# Spec 026 — Lunaris Design System reference docs (local-only, recreate on demand)
# argos-v2-mockup: extract from docs/Argos\ \(1\).zip (visual layout reference)
# carbon-design-system: git clone --depth 1 --filter=blob:none --sparse https://github.com/carbon-design-system/carbon.git
# carbon-website: git clone --depth 1 https://github.com/carbon-design-system/carbon-website.git
docs/argos-v2-mockup/
docs/carbon-design-system/
docs/carbon-website/
.fallow/

# Tessl tile cache — heavy binary artifacts shared across worktrees via
# spin-worktree.sh symlink. tessl.json + .tessl/RULES.md ARE tracked.
.tessl/tiles/
