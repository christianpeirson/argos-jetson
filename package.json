{
	"name": "argos",
	"description": "Real-time SDR & Network Analysis Console for Army EW training on Raspberry Pi 5",
	"version": "0.0.1",
	"private": true,
	"engines": {
		"node": ">=22.11"
	},
	"type": "module",
	"scripts": {
		"dev": "npm run kill-dev && PORT=$(./scripts/dev/port-for-worktree.sh) && tmux new-session -d -s argos-logs-$PORT \"./scripts/dev/start-vite.sh 2>&1 | tee /tmp/argos-dev-$PORT.log\" && rm -f /tmp/argos-dev-restart.lock && echo \"Argos dev started in tmux session: argos-logs-$PORT (port :$PORT)\" && echo \"Use: tmux attach -t argos-logs-$PORT\" && sleep 6 && lsof -ti:$PORT >/dev/null && echo \"Server UP on :$PORT\" || echo \"WARNING: Server may still be starting...\"",
		"dev:simple": "CI=true VITE_PORT=$(./scripts/dev/port-for-worktree.sh) ./scripts/dev/heap-tier.sh npx vite dev --port $VITE_PORT --host 0.0.0.0 --strictPort",
		"dev:logs": "tail -f /tmp/argos-dev.log",
		"dev:status": "lsof -ti:5173 >/dev/null 2>&1 && echo 'Server is RUNNING (tmux session: argos-logs)' || echo 'Server is NOT running'",
		"dev:attach": "tmux attach-session -t argos-logs",
		"dev:auto-kismet": "./scripts/dev/auto-start-kismet.sh && npm run dev",
		"dev:clean": "npm run kill-dev && npm run dev",
		"kismet:start": "./scripts/dev/start-kismet-with-alfa.sh",
		"kill-dev": "touch /tmp/argos-dev-restart.lock; tmux kill-session -t argos-logs 2>/dev/null; lsof -ti:5173 | xargs -r kill 2>/dev/null; sleep 1; lsof -ti:5173 | xargs -r kill -9 2>/dev/null || true",
		"build": "./scripts/ops/mem-guard.sh vite build",
		"build:force": "MEM_GUARD_SKIP=1 vite build",
		"preview": "vite preview",
		"check": "./scripts/ops/mem-guard.sh sh -c 'svelte-kit sync && svelte-check --tsconfig ./tsconfig.json'",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"typecheck": "./scripts/ops/mem-guard.sh sh -c 'svelte-kit sync && svelte-check --tsconfig ./tsconfig.json'",
		"lint": "./scripts/ops/mem-guard.sh eslint . --config config/eslint.config.js --cache --cache-location .eslintcache --cache-strategy content",
		"lint:fix": "./scripts/ops/mem-guard.sh eslint . --config config/eslint.config.js --cache --cache-location .eslintcache --cache-strategy content --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"postinstall": "node -e \"try{require('node-pty')}catch{process.exit(1)}\" 2>/dev/null || npx node-gyp rebuild --directory=node_modules/node-pty 2>/dev/null || true",
		"prepare": "husky || true",
		"test": "vitest",
		"test:unit": "./scripts/ops/mem-guard.sh vitest run src/ tests/unit --passWithNoTests",
		"test:integration": "./scripts/ops/mem-guard.sh vitest run tests/integration",
		"test:security": "./scripts/ops/mem-guard.sh vitest run tests/security",
		"test:visual": "./scripts/ops/mem-guard.sh vitest run tests/visual",
		"test:performance": "./scripts/ops/mem-guard.sh vitest run tests/performance",
		"db:migrate": "tsx scripts/db-migrate.ts",
		"db:rollback": "tsx src/lib/database/rollbackMigration.ts",
		"test:e2e": "./scripts/ops/mem-guard.sh playwright test",
		"test:smoke": "./scripts/ops/mem-guard.sh playwright test tests/e2e/smoke.test.ts",
		"test:watch": "vitest watch",
		"test:coverage": "./scripts/ops/mem-guard.sh vitest run --coverage",
		"test:ui": "vitest --ui",
		"test:visual:generate": "./scripts/ops/mem-guard.sh vitest run tests/visual -- --generate-baselines",
		"test:all": "./scripts/ops/mem-guard.sh sh -c 'vitest run src/ tests/unit --passWithNoTests && vitest run tests/integration && vitest run tests/visual && vitest run tests/performance'",
		"mcp:start": "tsx src/lib/server/mcp/dynamic-server.ts",
		"mcp:hardware": "tsx src/lib/server/mcp/servers/hardware-debugger.ts",
		"mcp:gsm-evil": "tsx src/lib/server/mcp/servers/gsm-evil-server.ts",
		"mcp:system": "tsx src/lib/server/mcp/servers/system-inspector.ts",
		"mcp:streaming": "tsx src/lib/server/mcp/servers/streaming-inspector.ts",
		"mcp:database": "tsx src/lib/server/mcp/servers/database-inspector.ts",
		"mcp:api": "tsx src/lib/server/mcp/servers/api-debugger.ts",
		"mcp:test": "tsx src/lib/server/mcp/servers/test-runner.ts",
		"mcp:install-b": "tsx scripts/ops/mcp-install.ts b",
		"mcp:config-b": "tsx scripts/ops/mcp-config.ts b",
		"commitlint": "commitlint --edit",
		"danger": "danger ci",
		"danger:local": "danger pr",
		"release:dry": "semantic-release --dry-run --no-ci",
		"test:unit:related": "./scripts/ops/mem-guard.sh ./scripts/dev/run-related-tests.sh staged",
		"test:unit:related:upstream": "./scripts/ops/mem-guard.sh ./scripts/dev/run-related-tests.sh upstream"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.1",
		"@commitlint/cli": "20.5.0",
		"@commitlint/config-conventional": "20.0.0",
		"@eslint/js": "9.39.2",
		"@lucide/svelte": "0.561.0",
		"@playwright/test": "1.60.0",
		"@semantic-release/changelog": "6.0.3",
		"@semantic-release/commit-analyzer": "13.0.0",
		"@semantic-release/git": "10.0.1",
		"@semantic-release/github": "11.0.0",
		"@semantic-release/release-notes-generator": "14.0.1",
		"@sveltejs/adapter-auto": "6.0.1",
		"@sveltejs/kit": "2.59.1",
		"@sveltejs/vite-plugin-svelte": "6.0.0",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.1.18",
		"@testing-library/jest-dom": "6.6.3",
		"@trunkio/launcher": "1.2.7",
		"@types/better-sqlite3": "7.6.13",
		"@types/cors": "2.8.19",
		"@types/cytoscape": "3.31.0",
		"@types/dotenv": "6.1.1",
		"@types/express": "5.0.3",
		"@types/geojson": "7946.0.16",
		"@types/leaflet": "1.9.21",
		"@types/leaflet.markercluster": "1.5.6",
		"@types/node": "24.0.12",
		"@types/novnc__novnc": "^1.6.0",
		"@types/ws": "8.18.1",
		"@typescript-eslint/eslint-plugin": "8.36.0",
		"@typescript-eslint/parser": "8.36.0",
		"@vitest/coverage-v8": "3.2.4",
		"@vitest/ui": "3.2.4",
		"archunit": "^2.1.69",
		"danger": "13.0.7",
		"eslint": "9.30.1",
		"eslint-config-prettier": "10.1.5",
		"eslint-plugin-boundaries": "^6.0.2",
		"eslint-plugin-simple-import-sort": "12.1.1",
		"eslint-plugin-sonarjs": "^4.0.3",
		"eslint-plugin-svelte": "3.10.1",
		"fallow": "2.63.0",
		"fast-check": "4.5.3",
		"globals": "16.5.0",
		"husky": "9.1.7",
		"jscpd": "4.0.8",
		"jsdom": "26.1.0",
		"lint-staged": "16.1.2",
		"madge": "8.0.0",
		"markdownlint-cli2": "0.22.1",
		"pixelmatch": "7.1.0",
		"pngjs": "7.0.0",
		"prettier": "3.6.2",
		"prettier-plugin-svelte": "3.4.0",
		"puppeteer": "24.12.1",
		"sass-embedded": "^1.99.0",
		"semantic-release": "24.2.3",
		"svelte": "5.55.5",
		"svelte-check": "4.2.2",
		"svelte-eslint-parser": "1.2.0",
		"tailwindcss": "4.1.18",
		"tsx": "4.20.3",
		"tw-animate-css": "1.4.0",
		"typescript": "5.8.3",
		"vite": "7.3.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "3.2.4"
	},
	"dependencies": {
		"@armyc2.c5isr.renderer/mil-sym-ts-web": "2.6.7",
		"@internationalized/date": "3.11.0",
		"@modelcontextprotocol/sdk": "1.26.0",
		"@novnc/novnc": "^1.6.0",
		"@sveltejs/adapter-node": "5.5.4",
		"@tailwindcss/forms": "0.5.10",
		"@tak-ps/node-cot": "14.30.1",
		"@tak-ps/node-tak": "12.15.3",
		"@xmldom/xmldom": "0.8.13",
		"@xterm/addon-fit": "0.11.0",
		"@xterm/addon-web-links": "0.12.0",
		"@xterm/xterm": "6.0.0",
		"better-sqlite3": "12.2.0",
		"carbon-components-svelte": "^0.107.0",
		"clsx": "2.1.1",
		"dotenv": "17.2.1",
		"eventsource": "4.0.0",
		"h3-js": "4.4.0",
		"leaflet": "1.9.4",
		"maplibre-gl": "5.6.1",
		"mgrs": "2.1.0",
		"mode-watcher": "1.1.0",
		"node-pty": "1.1.0",
		"svelte-maplibre-gl": "1.0.3",
		"tailwind-merge": "3.4.0",
		"tailwind-variants": "3.2.2",
		"ws": "8.18.3",
		"zod": "3.25.76"
	},
	"overrides": {
		"cookie": ">=0.7.0",
		"fast-xml-parser": ">=5.3.4"
	}
}
